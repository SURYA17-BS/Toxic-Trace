START

INITIALIZE system
    Initialize ESP32
    Initialize spectral sensor (I2C)
    Initialize OLED display
    Initialize button input
    Initialize WiFi and Firebase

SET calibration constants (m, c)

LOOP forever

    WAIT for button press

    // Step 1: Capture Reference (I₀)
    DISPLAY "Insert DI Water"
    DELAY for stabilization
    READ sensor multiple times
    CALCULATE average intensity → I0

    // Step 2: Capture Sample (I)
    DISPLAY "Insert Sample"
    DELAY for stabilization
    READ sensor multiple times
    CALCULATE average intensity → I

    // Step 3: Calculate Absorbance
    IF I <= 0 OR I0 <= 0
        DISPLAY "Error: Invalid reading"
        CONTINUE
    ENDIF

    A = log10(I0 / I)

    // Step 4: Convert to Concentration
    concentration = (A - c) / m

    // Step 5: Display Result
    DISPLAY concentration on OLED

    // Step 6: Send to Cloud
    SEND concentration, A, I0, I to Firebase

    // Step 7: Wait before next cycle
    DISPLAY "Press button to measure again"

END LOOP

END

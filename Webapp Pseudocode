12. PWA / SERVICE WORKER
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  ON service worker install:
    OPEN cache "ironsense-v1"
    CACHE files: index.html, manifest.json,
                 sw.js, symbiot.jpeg,
                 icon-192.png, icon-512.png

  ON fetch request:
    IF request exists in cache THEN
      RETURN cached version
    ELSE
      FETCH from network
    END IF


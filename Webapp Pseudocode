11. FIREBASE DATA STRUCTURE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  iron_monitor/
  └── device01/
      ├── command       ← "baseline" | "start" | "stop" | "reset"
      ├── lastSeen      ← Unix timestamp (ms) from ESP32 heartbeat
      ├── baseline/     ← stored baseline spectral values
      └── readings/
          └── <id>/
              ├── ppm        ← float (iron concentration)
              └── timestamp  ← Unix timestamp (ms)


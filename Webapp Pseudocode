10. THRESHOLD / PROTOCOL SELECTOR
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

  ON user changes protocol dropdown:

    PROTOCOL OPTIONS:
      WHO (Global)   → 0.30 mg/L
      BIS IS:10500   → 0.30 mg/L
      US-EPA         → 0.30 mg/L
      EU Directive   → 0.20 mg/L
      India (Perm.)  → 1.00 mg/L

    SET currentThreshold ← selected value
    UPDATE threshold display label
    RECALCULATE gauge with current PPM value
    LOG "X Limit: Y PPM"

